@model BetaSnapReporting.ViewModels.Report.ApplicantMasterViewModel
@using System.Text.Encodings.Web
@{
    Layout = "_Layout";
    ViewData["Title"] = "Applicant Master Report";
}

<link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

<div class="mb-4">
    <h3 class="fw-bold text-dark mb-1">Applicant Master Report</h3>
    <span class="text-secondary small fw-semibold text-uppercase tracking-wider">Beta SNAP Admissions Reporting Portal</span>
</div>

@if (!Model.FileExists)
{
    <div class="alert alert-danger shadow-sm border-start border-4 border-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
        <div>
            <strong>Ingestion Error:</strong> The reporting system cannot extract rows. The workbook file is missing from server storage paths.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border border-secondary border-opacity-25 mb-4">
        <div class="card-header bg-light text-dark py-2 d-flex align-items-center">
            <h6 class="card-title mb-0 fw-bold small text-uppercase text-dark-gray"><i class="bi bi-filter-square-fill me-1 text-secondary"></i>Filter Builder</h6>
        </div>
        <div class="card-body bg-body-tertiary p-3">
            <form method="get" asp-controller="Report" asp-action="Applicants" id="filterForm">

                <input type="hidden" id="removeIndex" name="removeIndex" value="" />

                <div class="row align-items-center mb-3">
                    <div class="col-md-3">
                        <label class="extra-small fw-bold text-dark-gray text-uppercase mb-1 d-block">Logical Match Criteria Rules</label>
                        <select name="LogicalOperator" class="form-select form-select-sm">
                            <!option value="AND" @(Model.ActiveFilter.LogicalOperator == "AND" ? "selected" : "")>Match ALL Conditions (AND)</!option>
                            <!option value="OR" @(Model.ActiveFilter.LogicalOperator == "OR" ? "selected" : "")>Match ANY Conditions (OR)</!option>
                        </select>
                    </div>
                </div>

                <div id="filterContainer">
                    @for (int idx = 0; idx < Model.ActiveFilter.Conditions.Count; idx++)
                    {
                        var rowViewData = new ViewDataDictionary(ViewData)
                        {
                            { "Index", idx },
                            { "Metadata", Model.MetadataSummary }
                        };
                        @await Html.PartialAsync("~/Views/Report/_FilterConditionRow.cshtml", Model.ActiveFilter.Conditions[idx], rowViewData)
                    }
                </div>

                <div class="mt-3 d-flex justify-content-between border-top pt-3">
                    <div>
                        <button type="submit" name="submitAction" value="AddRow" class="btn btn-sm btn-outline-dark fw-bold d-flex align-items-center">
                            <i class="bi bi-plus-circle-fill me-1"></i>Add Filter
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" name="submitAction" value="Reset" class="btn btn-sm btn-outline-secondary fw-semibold px-3">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset View
                        </button>
                        <button type="submit" name="submitAction" value="Filter" class="btn btn-sm btn-enterprise-primary fw-bold px-4">
                            <i class="bi bi-search me-1"></i>Apply Filters
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Rows Returned</span>
                <span class="fs-4 fw-bold text-dark">@(Model.IsFiltered ? Model.FilteredResultsCount.ToString("N0") : Model.TotalApplicantsCount.ToString("N0"))</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Total Records</span>
                <span class="fs-4 fw-bold text-dark">@Model.TotalApplicantsCount.ToString("N0")</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Execution Time</span>
                <span class="fs-4 fw-bold text-dark text-muted">0.024 <span class="fs-6 fw-normal">sec</span></span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Visible Columns</span>
                <span class="fs-4 fw-bold text-dark">@Model.MetadataSummary.TotalColumnsCount.ToString() <span class="fs-6 fw-normal">fields</span></span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border border-secondary border-opacity-25 mb-4">
        <div class="card-body py-2 px-3">
            <span class="extra-small fw-bold text-uppercase text-dark-gray d-block mb-1"><i class="bi bi-info-circle me-1"></i>Current Filters</span>
            @{
                var activeConditions = Model.ActiveFilter.Conditions
                    .Where(c => !string.IsNullOrWhiteSpace(c.ColumnName) && (!string.IsNullOrWhiteSpace(c.Value) || !string.IsNullOrWhiteSpace(c.Value2)))
                    .ToList();
            }
            @if (!activeConditions.Any())
            {
                <span class="text-muted small">No active filters</span>
            }
            else
            {
                <ul class="list-unstyled mb-1 small">
                    @foreach (var cond in activeConditions)
                    {
                        var colMeta = Model.MetadataSummary.Columns.FirstOrDefault(c => c.ColumnName == cond.ColumnName);
                        var label = colMeta?.DisplayName ?? cond.ColumnName;
                        string displayValue = cond.Operator == "Between"
                            ? $"{cond.Value} - {cond.Value2}"
                            : cond.Value.Replace(",", ", ");
                        <li><span class="fw-semibold">@label</span> <span class="text-muted">@cond.Operator</span> <span>@displayValue</span></li>
                    }
                </ul>
                <span class="extra-small text-muted">Logic: Match @(Model.ActiveFilter.LogicalOperator == "AND" ? "ALL" : "ANY") Conditions (@Model.ActiveFilter.LogicalOperator)</span>
            }
        </div>
    </div>

    <div class="card shadow-sm border border-secondary border-opacity-25 mb-4">
        <div class="card-header bg-light text-dark py-2 d-flex align-items-center">
            <h6 class="card-title mb-0 fw-bold small text-uppercase text-dark-gray"><i class="bi bi-eye-fill me-1 text-secondary"></i>Visible Columns</h6>
        </div>
        <div class="card-body bg-body-tertiary p-3">
            <input type="hidden" name="VisibleColumnsSubmitted" value="true" form="filterForm" />
            <div class="d-flex flex-wrap gap-3">
                @foreach (var col in Model.MetadataSummary.Columns)
                {
                    bool isChecked = Model.ActiveFilter.VisibleColumns.Contains(col.ColumnName, StringComparer.OrdinalIgnoreCase);
                    <div class="form-check">
                        <input type="checkbox" name="VisibleColumns" value="@col.ColumnName" class="form-check-input" id="col_@col.ColumnName.GetHashCode()" form="filterForm" @(isChecked ? "checked" : "") />
                        <label class="form-check-label small" for="col_@col.ColumnName.GetHashCode()">@col.DisplayName</label>
                    </div>
                }
            </div>
            <div class="mt-3">
                <button type="submit" name="submitAction" value="" form="filterForm" class="btn btn-sm btn-outline-dark fw-semibold px-3">
                    <i class="bi bi-arrow-repeat me-1"></i>Update Columns
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border border-secondary border-opacity-25">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
            <span class="extra-small fw-bold text-dark-gray text-uppercase"><i class="bi bi-table me-1"></i>Data Grid Viewer</span>
            <div class="d-flex gap-2">
                <button type="submit" form="filterForm" formaction="@Url.Action("ExportCsv", "Report")" formmethod="get" class="btn btn-xs btn-outline-secondary py-0 px-2 extra-small">
                    <i class="bi bi-filetype-csv me-1"></i>CSV Export
                </button>
                <button type="submit" form="filterForm" formaction="@Url.Action("ExportExcel", "Report")" formmethod="get" class="btn btn-xs btn-outline-secondary py-0 px-2 extra-small">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel Export
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-viewport-container">
                <table class="table table-striped table-hover table-bordered table-enterprise align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col" class="py-2 px-3 text-nowrap">S.No</th>
                            @foreach (var header in Model.ColumnHeaders)
                            {
                                <th scope="col" class="py-2 px-3 text-nowrap">@header</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SampleRecords.Any())
                        {
                            int serialNo = (Model.CurrentPage - 1) * Model.PageSize + 1;
                            @foreach (var row in Model.SampleRecords)
                            {
                                <tr>
                                    <td class="px-3 text-muted">@serialNo</td>
                                    @foreach (var header in Model.ColumnHeaders)
                                    {
                                        <td class="px-3" title="@(row.TryGetValue(header, out var val) ? val?.ToString() : string.Empty)">
                                            @(row.TryGetValue(header, out var cellVal) ? cellVal?.ToString() : string.Empty)
                                        </td>
                                    }
                                </tr>
                                serialNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@Math.Max(1, Model.ColumnHeaders.Count + 1)" class="text-center text-muted py-5">
                                    <i class="bi bi-info-circle-fill fs-5 me-1 text-warning d-block mb-2"></i>No records match the requested filter parameters.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
            @{
                int rangeStart = Model.FilteredResultsCount == 0 ? 0 : (Model.CurrentPage - 1) * Model.PageSize + 1;
                int rangeEnd = Math.Min(Model.CurrentPage * Model.PageSize, Model.FilteredResultsCount);
            }
            <span class="extra-small text-muted">
                Showing @rangeStart-@rangeEnd of @Model.FilteredResultsCount.ToString("N0") rows
            </span>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Result pages">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <button type="submit" form="filterForm" formaction="@Url.Action("Applicants", "Report")" formmethod="get"
                                    name="pageNumber" value="@(Model.CurrentPage - 1)" class="page-link" @(Model.CurrentPage == 1 ? "disabled" : "")>
                                Previous
                            </button>
                        </li>

                        @{
                            int windowSize = 2;
                            int startPage = Math.Max(1, Model.CurrentPage - windowSize);
                            int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + windowSize);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <button type="submit" form="filterForm" formaction="@Url.Action("Applicants", "Report")" formmethod="get" name="pageNumber" value="1" class="page-link">1</button>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                        }

                        @for (int p = startPage; p <= endPage; p++)
                        {
                            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                <button type="submit" form="filterForm" formaction="@Url.Action("Applicants", "Report")" formmethod="get" name="pageNumber" value="@p" class="page-link">@p</button>
                            </li>
                        }

                        @if (endPage < Model.TotalPages)
                        {
                            if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            <li class="page-item">
                                <button type="submit" form="filterForm" formaction="@Url.Action("Applicants", "Report")" formmethod="get" name="pageNumber" value="@Model.TotalPages" class="page-link">@Model.TotalPages</button>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <button type="submit" form="filterForm" formaction="@Url.Action("Applicants", "Report")" formmethod="get"
                                    name="pageNumber" value="@(Model.CurrentPage + 1)" class="page-link" @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")>
                                Next
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

    <script>
        let categoricalValuesDictionary = {};
        @foreach (var col in Model.MetadataSummary.Columns.Where(c => c.DataType == "Categorical" || c.DataType == "Boolean"))
        {
            <text>categoricalValuesDictionary["@JavaScriptEncoder.Default.Encode(col.ColumnName)"] = @Html.Raw(Json.Serialize(col.UniqueValues));</text>
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".ts-categorical-select").forEach(initTomSelectForRow);
            document.querySelectorAll(".filter-entry-row").forEach(row => syncRowWidgetDisplay(row));
        });

        function initTomSelectForRow(selectEl) {
            const hiddenInput = selectEl.closest(".widget-box").querySelector(".hidden-serialized-value");
            const ts = new TomSelect(selectEl, {
                plugins: ["remove_button"],
                persist: false,
                create: false,
                onChange: values => { hiddenInput.value = Array.isArray(values) ? values.join(",") : values; }
            });
            selectEl.tomSelectInstance = ts;

            // Record which column this TomSelect instance currently reflects, so later loads
            // never mistake "already correct" for "needs refreshing" and wipe the selection.
            const row = selectEl.closest(".filter-entry-row");
            selectEl.dataset.initializedColumn = row ? row.querySelector(".field-selector").value : "";
            hiddenInput.value = ts.getValue().join(",");
        }

        // Pure visual show/hide. Safe to call on every page load AND on column change.
        // Never touches TomSelect's data, so it can never wipe a restored selection.
        function syncRowWidgetDisplay(row) {
            const select = row.querySelector(".field-selector");
            const option = select.options[select.selectedIndex];
            const widgetType = option ? (option.getAttribute("data-widget") || "TextBox") : "TextBox";

            row.querySelectorAll(".widget-box").forEach(box => {
                const isActive = box.getAttribute("data-widget") === widgetType;
                box.classList.toggle("d-none", !isActive);
                box.querySelectorAll("input, select").forEach(field => {
                    field.disabled = !isActive;
                });
            });

            toggleBetweenInputs(row);
        }

        // Fired ONLY by the field-selector's onchange — a genuine user-driven column switch.
        // Never fired on page load, so restored filter state is never touched.
        function onColumnChange(row) {
            syncRowWidgetDisplay(row);

            const select = row.querySelector(".field-selector");
            const option = select.options[select.selectedIndex];
            const widgetType = option ? (option.getAttribute("data-widget") || "TextBox") : "TextBox";
            const columnName = select.value;

            if (widgetType === "MultiSelectDropdown") {
                const selectEl = row.querySelector(".ts-categorical-select");
                if (selectEl && selectEl.dataset.initializedColumn !== columnName) {
                    refreshCategoricalOptions(row, columnName);
                    selectEl.dataset.initializedColumn = columnName;
                }
            }
        }

        function refreshCategoricalOptions(row, columnName) {
            const selectEl = row.querySelector(".ts-categorical-select");
            if (!selectEl || !selectEl.tomSelectInstance) return;

            const ts = selectEl.tomSelectInstance;
            const values = categoricalValuesDictionary[columnName] || [];

            ts.clear(true);
            ts.clearOptions();
            values.forEach(v => ts.addOption({ value: v, text: v }));
            ts.refreshOptions(false);

            const hiddenInput = selectEl.closest(".widget-box").querySelector(".hidden-serialized-value");
            if (hiddenInput) hiddenInput.value = "";
        }

        function toggleBetweenInputs(row) {
            const operator = row.querySelector(".operator-selector").value;
            row.querySelectorAll(".range-input").forEach(el => {
                const isBetween = operator === "Between";
                el.classList.toggle("d-none", !isBetween);
                el.querySelectorAll("input").forEach(field => {
                    if (!field.closest(".widget-box").classList.contains("d-none")) {
                        field.disabled = !isBetween;
                    }
                });
            });
        }

        function serializeCheckboxes(row) {
            const checked = Array.from(row.querySelectorAll(".row-checkbox:checked")).map(cb => cb.value);
            row.querySelector(".hidden-serialized-value").value = checked.join(',');
        }
    </script>
}