<!-- Applicants.cshtml -->
@model BetaSnapReporting.ViewModels.Report.ApplicantMasterViewModel
@using System.Text.Encodings.Web
@{
    Layout = "_Layout";
    ViewData["Title"] = "Applicant Master Report";
}

<div class="mb-4">
    <h3 class="fw-bold text-dark mb-1">Applicant Master Report</h3>
    <span class="text-secondary small fw-semibold text-uppercase tracking-wider">Beta SNAP Admissions Reporting Portal</span>
</div>

@if (!Model.FileExists)
{
    <div class="alert alert-danger shadow-sm border-start border-4 border-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
        <div>
            <strong>Ingestion Error:</strong> The reporting system cannot extract rows. The workbook file is missing from server storage paths.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border border-secondary border-opacity-25 mb-4">
        <div class="card-header bg-light text-dark py-2 d-flex align-items-center">
            <h6 class="card-title mb-0 fw-bold small text-uppercase text-dark-gray"><i class="bi bi-filter-square-fill me-1 text-secondary"></i>Filter Builder</h6>
        </div>
        <div class="card-body bg-body-tertiary p-3">
            <form method="get" asp-controller="Report" asp-action="Applicants" id="filterForm">
                
                <input type="hidden" id="removeIndex" name="removeIndex" value="" />

                <div class="row align-items-center mb-3">
                    <div class="col-md-3">
                        <label class="extra-small fw-bold text-dark-gray text-uppercase mb-1 d-block">Logical Match Criteria Rules</label>
                        <select name="LogicalOperator" class="form-select form-select-sm">
                            <!option value="AND" @(Model.ActiveFilter.LogicalOperator == "AND" ? "selected" : "")>Match ALL Conditions (AND)</!option>
                            <!option value="OR" @(Model.ActiveFilter.LogicalOperator == "OR" ? "selected" : "")>Match ANY Conditions (OR)</!option>
                        </select>
                    </div>
                </div>

                <div id="filterContainer">
                    @for (int idx = 0; idx < Model.ActiveFilter.Conditions.Count; idx++)
                    {
                        var rowViewData = new ViewDataDictionary(ViewData)
                        {
                            { "Index", idx },
                            { "Metadata", Model.MetadataSummary }
                        };
                        @await Html.PartialAsync("~/Views/Report/_FilterConditionRow.cshtml", Model.ActiveFilter.Conditions[idx], rowViewData)
                    }
                </div>

                <div class="mt-3 d-flex justify-content-between border-top pt-3">
                    <div>
                        <button type="submit" name="submitAction" value="AddRow" class="btn btn-sm btn-outline-dark fw-bold d-flex align-items-center">
                            <i class="bi bi-plus-circle-fill me-1"></i>Add Filter
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" name="submitAction" value="Reset" class="btn btn-sm btn-outline-secondary fw-semibold px-3">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset View
                        </button>
                        <button type="submit" name="submitAction" value="Filter" class="btn btn-sm btn-enterprise-primary fw-bold px-4">
                            <i class="bi bi-search me-1"></i>Apply Filters
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Rows Returned</span>
                <span class="fs-4 fw-bold text-dark">@(Model.IsFiltered ? Model.FilteredResultsCount.ToString("N0") : Model.TotalApplicantsCount.ToString("N0"))</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Total Records</span>
                <span class="fs-4 fw-bold text-dark">@Model.TotalApplicantsCount.ToString("N0")</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Execution Time</span>
                <span class="fs-4 fw-bold text-dark text-muted">0.024 <span class="fs-6 fw-normal">sec</span></span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border border-light p-3 bg-white">
                <span class="text-secondary extra-small fw-bold text-uppercase d-block mb-1">Visible Columns</span>
                <span class="fs-4 fw-bold text-dark">@Model.MetadataSummary.TotalColumnsCount.ToString() <span class="fs-6 fw-normal">fields</span></span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border border-secondary border-opacity-25">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
            <span class="extra-small fw-bold text-dark-gray text-uppercase"><i class="bi bi-table me-1"></i>Data Grid Viewer</span>
            <button class="btn btn-xs btn-outline-secondary py-0 px-2 extra-small opacity-50" disabled><i class="bi bi-download me-1"></i>Excel Export</button>
        </div>
        <div class="card-body p-0">
            <div class="table-viewport-container">
                <table class="table table-striped table-hover table-bordered table-enterprise align-middle mb-0">
                    <thead>
                        <tr>
                            @foreach (var header in Model.ColumnHeaders)
                            {
                                <th scope="col" class="py-2 px-3 text-nowrap">@header</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SampleRecords.Any())
                        {
                            @foreach (var row in Model.SampleRecords)
                            {
                                <tr>
                                    @foreach (var header in Model.ColumnHeaders)
                                    {
                                        <td class="px-3" title="@(row.TryGetValue(header, out var val) ? val?.ToString() : string.Empty)">
                                            @(row.TryGetValue(header, out var cellVal) ? cellVal?.ToString() : string.Empty)
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@Math.Max(1, Model.ColumnHeaders.Count)" class="text-center text-muted py-5">
                                    <i class="bi bi-info-circle-fill fs-5 me-1 text-warning d-block mb-2"></i>No records match the requested filter parameters.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        let categoricalValuesDictionary = {};
        @foreach (var col in Model.MetadataSummary.Columns.Where(c => c.DataType == "Categorical" || c.DataType == "Boolean"))
        {
            <text>categoricalValuesDictionary["@JavaScriptEncoder.Default.Encode(col.ColumnName)"] = @Html.Raw(Json.Serialize(col.UniqueValues));</text>
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".filter-entry-row").forEach(row => syncRowWidgetDisplay(row));
        });

        function syncRowWidgetDisplay(row) {
            const select = row.querySelector(".field-selector");
            const option = select.options[select.selectedIndex];
            let dataType = option ? option.getAttribute("data-type") : "Text";
            if (!dataType) dataType = "Text";

            const resolvedWidgetType = (dataType === "Boolean") ? "Categorical" : dataType;

            row.querySelectorAll(".widget-box").forEach(box => {
                const isActive = box.getAttribute("data-widget") === resolvedWidgetType;
                box.classList.toggle("d-none", !isActive);
                box.querySelectorAll("input, select").forEach(field => {
                    field.disabled = !isActive;
                });
            });

            toggleBetweenInputs(row);
        }

        function toggleBetweenInputs(row) {
            const operator = row.querySelector(".operator-selector").value;
            row.querySelectorAll(".range-input").forEach(el => {
                const isBetween = operator === "Between";
                el.classList.toggle("d-none", !isBetween);
                el.querySelectorAll("input").forEach(field => {
                    if (!field.closest(".widget-box").classList.contains("d-none")) {
                        field.disabled = !isBetween;
                    }
                });
            });
        }

        function serializeCheckboxes(row) {
            const checked = Array.from(row.querySelectorAll(".row-checkbox:checked")).map(cb => cb.value);
            row.querySelector(".hidden-serialized-value").value = checked.join(',');
        }
    </script>
}